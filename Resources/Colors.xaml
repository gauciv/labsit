<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Crextio Color Theme -->
    <SolidColorBrush x:Key="PageBgBrush"       Color="#E8EEF7"/>
    <SolidColorBrush x:Key="CardBgBrush"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBgSoftBrush"   Color="#F0F4FA"/>
    <SolidColorBrush x:Key="DarkCardBrush"     Color="#1E3A6E"/>
    <SolidColorBrush x:Key="PrimaryBrush"      Color="#1A6FE8"/>
    <SolidColorBrush x:Key="AccentBrush"       Color="#4B9BFF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#1A1D2E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextMutedBrush"    Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#E5E7EB"/>
    <SolidColorBrush x:Key="TrackBrush"        Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ProgressBrush"     Color="#2563EB"/>

</ResourceDictionary>
