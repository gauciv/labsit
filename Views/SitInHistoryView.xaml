<UserControl x:Class="LaboratorySitInSystem.Views.SitInHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:LaboratorySitInSystem.Helpers">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Sit-In History" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Filters -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="From Date"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="140"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="To Date"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="140"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="Student ID"/>
                <TextBox Text="{Binding StudentIdFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="Subject"/>
                <TextBox Text="{Binding SubjectFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4"/>
            </StackPanel>
            <StackPanel Margin="0,0,4,4" VerticalAlignment="Bottom">
                <Button Content="Search" Command="{Binding SearchCommand}" Padding="12,4"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,4" VerticalAlignment="Bottom">
                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Padding="12,4"/>
            </StackPanel>
        </WrapPanel>

        <!-- History DataGrid -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Sessions}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  CanUserAddRows="False" 
                  Margin="0,0,0,10"
                  HorizontalScrollBarVisibility="Auto"
                  Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibility}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="100"/>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*" MinWidth="100"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat='MM/dd/yyyy hh:mm tt'}" Width="140"/>
                <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat='MM/dd/yyyy hh:mm tt'}" Width="140"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="80"/>
                <DataGridCheckBoxColumn Header="Scheduled" Binding="{Binding IsScheduled}" Width="80"/>
                <DataGridCheckBoxColumn Header="Early Ended" Binding="{Binding EarlyEnded}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Margin="40"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
            
            <!-- Icon -->
            <Border Background="#F3F4F6"
                    Width="80"
                    Height="80"
                    CornerRadius="40"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24">
                <TextBlock Text="📊" 
                           FontSize="40"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            
            <!-- Title -->
            <TextBlock Text="No History Records" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            
            <!-- Subtitle -->
            <TextBlock Text="No sit-in sessions match your search criteria. Try adjusting your filters or check back later."
                       FontSize="14"
                       Foreground="#6B7280"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       Margin="0,0,0,24"/>
            
            <!-- Info Text -->
            <TextBlock FontSize="13"
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
                <Run Text="Session history will appear here once students complete their sit-ins."/>
            </TextBlock>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontStyle="Italic"/>
    </Grid>
</UserControl>
