<UserControl x:Class="LaboratorySitInSystem.Views.SitInHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Sit-In History" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Filters -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="From Date"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="140"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="To Date"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="140"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="Student ID"/>
                <TextBox Text="{Binding StudentIdFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4"/>
            </StackPanel>
            <StackPanel Margin="0,0,12,4">
                <TextBlock Text="Subject"/>
                <TextBox Text="{Binding SubjectFilter, UpdateSourceTrigger=PropertyChanged}" Width="120" Padding="4"/>
            </StackPanel>
            <StackPanel Margin="0,0,4,4" VerticalAlignment="Bottom">
                <Button Content="Search" Command="{Binding SearchCommand}" Padding="12,4"/>
            </StackPanel>
            <StackPanel Margin="0,0,0,4" VerticalAlignment="Bottom">
                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Padding="12,4"/>
            </StackPanel>
        </WrapPanel>

        <!-- History DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Sessions}"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  CanUserAddRows="False" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student ID" Binding="{Binding StudentId}" Width="120"/>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat=g}" Width="140"/>
                <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat=g}" Width="140"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="100"/>
                <DataGridTextColumn Header="Scheduled" Binding="{Binding IsScheduled}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" FontStyle="Italic"/>
    </Grid>
</UserControl>
