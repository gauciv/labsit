<UserControl x:Class="LaboratorySitInSystem.Views.ActiveSessionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Active Sessions" FontSize="18" FontWeight="Bold" DockPanel.Dock="Left"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" DockPanel.Dock="Right"
                    Padding="12,4" HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Alarm Indicator -->
        <Border Grid.Row="1" Padding="8" CornerRadius="4" Margin="0,0,0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAlarmActive}" Value="True">
                            <Setter Property="Background" Value="#FFCDD2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="SemiBold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlarmActive}" Value="True">
                                <Setter Property="Foreground" Value="#C62828"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- Sessions DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding ActiveSessions}" SelectedItem="{Binding SelectedSession}"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  CanUserAddRows="False" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="*"/>
                <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat=hh:mm tt}" Width="120"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="100"/>
                <DataGridTextColumn Header="Scheduled" Binding="{Binding IsScheduled}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Force End Session" Command="{Binding ForceEndSessionCommand}" Padding="12,4"
                    Background="#C62828" Foreground="White"/>
        </StackPanel>
    </Grid>
</UserControl>
