<UserControl x:Class="LaboratorySitInSystem.Views.StudentSessionDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E9E9E"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E9E9E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Top Bar -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Lab" Foreground="#8BC34A" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="SitIn System" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,12,0"/>
                    <Border Background="#4CAF50" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock Text="Session Active" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Student.FullName}" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Background="#7C4DFF" CornerRadius="14" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Student.FirstName[0]}" Foreground="White" FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button Content="Log out" Command="{Binding LogoutCommand}" Padding="10,4"
                            Background="#3E3E42" Foreground="White" BorderBrush="#555" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>

            <!-- Row 1: Warning Banner -->
            <Border Grid.Row="1" Background="#F57F17" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ShowWarning, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="16" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SessionWarning}" Foreground="White" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Row 2: Welcome + Time Remaining -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="4,0,4,12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White">
                            <Run Text="Welcome back, "/><Run Text="{Binding Student.FirstName, Mode=OneWay}"/><Run Text="!"/>
                        </TextBlock>
                        <TextBlock Text="Approved sit-in session" Foreground="#9E9E9E" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Time remaining" Foreground="#9E9E9E" FontSize="11" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TimeRemainingDisplay}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowWarning}" Value="True">
                                            <Setter Property="Foreground" Value="#FF5722"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Row 3: Stat Cards (3 cards) -->
            <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,12">
                <!-- Time In -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Time in" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding TimeInDisplay}" Style="{StaticResource ValueText}"/>
                        <TextBlock Text="Today" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Allowed Duration -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Allowed duration" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding AllowedDurationDisplay}" Style="{StaticResource ValueText}"/>
                        <TextBlock Text="Per schedule" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Sit-in Count -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Sit-in count" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding SitInCount}" Style="{StaticResource ValueText}"/>
                        <TextBlock Text="Total sessions" Style="{StaticResource LabelText}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 4: Student Info + Today's Schedule -->
            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Student Info -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="STUDENT INFO" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID Number" Foreground="#9E9E9E" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Student.StudentId}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Foreground="#9E9E9E" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Student.FullName}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Course" Foreground="#9E9E9E" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Student.Course}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Year Level" Foreground="#9E9E9E" Margin="0,0,20,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Student.YearLevel}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Today's Schedule -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SCHEDULE" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl ItemsSource="{Binding TodaySchedules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#2196F3"/>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding SubjectName}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Foreground="#9E9E9E" FontSize="11" Margin="16,2,0,0">
                                            <Run Text="{Binding StartTime, StringFormat=hh\\:mm, Mode=OneWay}"/>
                                            <Run Text=" – "/>
                                            <Run Text="{Binding EndTime, StringFormat=hh\\:mm, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No schedules today" Foreground="#666" FontStyle="Italic"
                                   Visibility="{Binding TodaySchedules.Count, Converter={StaticResource NullToCollapsed}}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 5: Sit-In Log History -->
            <Border Grid.Row="5" Style="{StaticResource CardBorder}" Margin="4,0,4,12">
                <StackPanel>
                    <TextBlock Text="SIT-IN LOG HISTORY" Style="{StaticResource SectionTitle}"/>
                    <DataGrid ItemsSource="{Binding RecentHistory}" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single"
                              Background="Transparent" Foreground="White" BorderThickness="0"
                              RowBackground="#2D2D30" AlternatingRowBackground="#333"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#444"
                              HeadersVisibility="Column" MaxHeight="200">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="StartTime" StringFormat="MMM dd, yyyy"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                            <DataGridTextColumn Header="Time in" Width="100">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="StartTime" StringFormat="h:mm tt"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Time out" Width="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="EndTime" StringFormat="h:mm tt" TargetNullValue="— (active)"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Row 6: Status Message -->
            <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Foreground="#FF5722" FontStyle="Italic"
                       Margin="4,0,4,8" TextWrapping="Wrap"/>

            <!-- Row 7: End Session Button -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="4,0,4,16">
                <Button Command="{Binding EndSessionEarlyCommand}" Padding="16,8" Cursor="Hand"
                        Background="#C62828" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        BorderBrush="#B71C1C" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏹" Margin="0,0,6,0"/>
                        <TextBlock Text="End session early"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
