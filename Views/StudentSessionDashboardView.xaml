<UserControl x:Class="LaboratorySitInSystem.Views.StudentSessionDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:LaboratorySitInSystem.Helpers"
             Background="{StaticResource PageBgBrush}">
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <helpers:TimeSpanToStringConverter x:Key="TimeSpanToString"/>
        
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#E5E7EB" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="IconCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource CardBgBrush}" CornerRadius="12" Margin="0,0,0,16" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect Color="#E5E7EB" Direction="270" ShadowDepth="1" BlurRadius="4" Opacity="0.2"/>
                </Border.Effect>
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <TextBlock Text="🔬" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Lab" Foreground="{StaticResource PrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="SitIn System" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold" Margin="4,0,0,0"/>
                            </StackPanel>
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="12" Padding="8,4" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource TextOnDarkBrush}" Margin="0,0,6,0"/>
                                    <TextBlock Text="Session Active" Foreground="{StaticResource TextOnDarkBrush}" FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Margin="0,0,16,0">
                            <TextBlock Text="{Binding Student.FullName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding Student.Course}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="20" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="{Binding Student.FirstName[0]}" Foreground="{StaticResource TextOnDarkBrush}" FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Button Style="{StaticResource IconButton}" Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Log out" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Row 1: Warning Banner -->
            <Border Grid.Row="1" Background="{StaticResource AccentBrush}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16"
                    Visibility="{Binding ShowWarning, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="{Binding Source={StaticResource AccentBrush}, Path=Color}" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource TextOnDarkBrush}" CornerRadius="16" Width="32" Height="32" Margin="0,0,12,0">
                        <TextBlock Text="⚠️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Session Warning" Foreground="{StaticResource TextOnDarkBrush}" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SessionWarning}" Foreground="{StaticResource TextOnDarkBrush}" FontSize="13" TextWrapping="Wrap" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Row 2: Welcome + Time Remaining -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="6,0,6,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="👋" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                    <Run Text="Welcome back, "/><Run Text="{Binding Student.FirstName, Mode=OneWay}"/><Run Text="!"/>
                                </TextBlock>
                                <TextBlock Text="Approved sit-in session" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Background="{StaticResource CardBgSoftBrush}" CornerRadius="16" Padding="20,16" HorizontalAlignment="Right">
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="⏰" FontSize="20" Margin="0,0,8,0"/>
                                <TextBlock Text="Time Remaining" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TimeRemainingDisplay}" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowWarning}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Row 3: Stat Cards -->
            <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,20">
                <Border Style="{StaticResource IconCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="🕐" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Time In" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="Today" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding TimeInDisplay}" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource IconCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="📅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Duration" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="Per Schedule" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding AllowedDurationDisplay}" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource IconCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{StaticResource ProgressBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Sessions" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="Total Count" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding SitInCount}" Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 4: Student Info + Today's Schedule -->
            <Grid Grid.Row="4" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="STUDENT INFO" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID Number" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Student.StudentId}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Student.FullName}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Course" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Student.Course}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Year Level" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,20,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Student.YearLevel}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="TODAY'S SCHEDULE" Style="{StaticResource SectionTitle}"/>
                        
                        <!-- Schedule List -->
                        <ItemsControl ItemsSource="{Binding TodaySchedules}"
                                      Visibility="{Binding IsTodaySchedulesEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SubjectName}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="16,2,0,0">
                                            <Run Text="{Binding StartTime, Converter={StaticResource TimeSpanToString}, Mode=OneWay}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding EndTime, Converter={StaticResource TimeSpanToString}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Empty State -->
                        <StackPanel Visibility="{Binding IsTodaySchedulesEmpty, Converter={StaticResource BoolToVisibility}}"
                                    HorizontalAlignment="Center"
                                    Margin="0,20">
                            <TextBlock Text="📅" 
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="No schedules today" 
                                       Foreground="{StaticResource TextMutedBrush}" 
                                       FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 5: Sit-In Log History -->
            <Border Grid.Row="5" Style="{StaticResource CardBorder}" Margin="4,0,4,12">
                <StackPanel>
                    <TextBlock Text="SIT-IN LOG HISTORY" Style="{StaticResource SectionTitle}"/>
                    
                    <!-- DataGrid -->
                    <DataGrid ItemsSource="{Binding RecentHistory}" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True" 
                              CanUserAddRows="False" 
                              SelectionMode="Single"
                              Background="{StaticResource CardBgBrush}" 
                              Foreground="{StaticResource TextPrimaryBrush}" 
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderBrush}"
                              RowBackground="{StaticResource CardBgBrush}" 
                              AlternatingRowBackground="{StaticResource CardBgSoftBrush}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                              HeadersVisibility="Column" 
                              MaxHeight="200"
                              Visibility="{Binding IsRecentHistoryEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Width="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="StartTime" StringFormat="MMM dd yyyy"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*"/>
                            <DataGridTextColumn Header="Time in" Width="100">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="StartTime" StringFormat="h:mm tt"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Time out" Width="120">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="EndTime" StringFormat="h:mm tt" TargetNullValue="- (active)"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Empty State -->
                    <StackPanel Visibility="{Binding IsRecentHistoryEmpty, Converter={StaticResource BoolToVisibility}}"
                                HorizontalAlignment="Center"
                                Margin="0,40">
                        <TextBlock Text="📊" 
                                   FontSize="40"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="No History Yet" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Your sit-in history will appear here" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Row 6: Status Message -->
            <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" Foreground="{StaticResource PrimaryBrush}" FontStyle="Italic"
                       Margin="4,0,4,8" TextWrapping="Wrap"/>

            <!-- Row 7: End Session Button -->
            <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="6,0,6,20">
                <Button Command="{Binding EndSessionEarlyCommand}" Cursor="Hand"
                        Background="{StaticResource PrimaryBrush}" 
                        Foreground="{StaticResource TextOnDarkBrush}" 
                        FontSize="14" FontWeight="SemiBold"
                        BorderThickness="0"
                        Padding="20,12">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Effect>
                                                <DropShadowEffect Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}" Direction="270" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="End Session Early"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>
