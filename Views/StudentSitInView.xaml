<UserControl x:Class="LaboratorySitInSystem.Views.StudentSitInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource CardBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side - Student Sit-In Form -->
        <Grid Grid.Column="0" Background="{StaticResource CardBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo and Brand -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="40,30,40,0">
                <Image Source="/Assets/labsit logo.jpg" 
                       Width="50" 
                       Height="50" 
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="LabSit" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Student Sit-In Form Container -->
            <Border Grid.Row="1" 
                    Padding="40,20,40,40" 
                    VerticalAlignment="Center">
                <StackPanel MaxWidth="400">
                    
                    <!-- Welcome Header -->
                    <StackPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="12" Padding="12" Margin="0,0,16,0">
                                <TextBlock Text="🎓" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Student Sit-In" 
                                           FontSize="32" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Laboratory Access System" 
                                           FontSize="14" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBlock Text="Enter your Student ID to start your session" 
                               FontSize="14" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,32"
                               TextWrapping="Wrap"/>

                    <!-- Student ID Field -->
                    <StackPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🆔" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Student ID" 
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Border Background="{StaticResource CardBgSoftBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="8">
                            <TextBox Text="{Binding StudentIdInput, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="16,12" 
                                     FontSize="16"
                                     FontWeight="Medium"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="13"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Matched Schedule Info -->
                    <Border Visibility="{Binding MatchedSchedule, Converter={StaticResource NullToCollapsed}}" 
                            Background="{StaticResource CardBgSoftBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Matched Schedule" 
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Subject: "/><Run Text="{Binding MatchedSchedule.SubjectName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Day: "/><Run Text="{Binding MatchedSchedule.DayOfWeek, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Student Info -->
                    <Border Visibility="{Binding CurrentStudent, Converter={StaticResource NullToCollapsed}}" 
                            Background="{StaticResource CardBgSoftBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Student Info" 
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Name: "/><Run Text="{Binding CurrentStudent.FullName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Course: "/><Run Text="{Binding CurrentStudent.Course, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Login / Start Session Button -->
                    <Button Content="Login / Start Session" 
                            Command="{Binding LoginCommand}" 
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="{StaticResource TextOnDarkBrush}"
                            BorderThickness="0"
                            Padding="0,14"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="0,0,0,16">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Back to Login Button -->
                    <Button Content="Back to Login" 
                            Command="{Binding GoBackCommand}" 
                            Background="{StaticResource CardBgSoftBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="0,14"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="0,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Right Side - Image -->
        <Grid Grid.Column="1" Background="{StaticResource PageBgBrush}">
            <Border Background="{StaticResource PageBgBrush}" 
                    Padding="20">
                <Border CornerRadius="12"
                        ClipToBounds="True"
                        Background="{StaticResource CardBgBrush}">
                    <Grid>
                        <!-- Laboratory Building Image -->
                        <Image Source="/Assets/ctu.jpg" 
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        
                        <!-- Fallback if image is not found -->
                        <Border Background="{StaticResource DarkCardBrush}"
                                Visibility="Collapsed">
                            <TextBlock Text="Laboratory Building&#x0a;&#x0a;Image not found:&#x0a;Assets/ctu.jpg" 
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextOnDarkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       LineHeight="24"/>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
