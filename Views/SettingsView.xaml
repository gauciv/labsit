<UserControl x:Class="LaboratorySitInSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Width="400" Margin="0,20,0,0">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Alarm Threshold (number of active sessions)" Margin="0,0,0,4"/>
            <TextBox Text="{Binding AlarmThreshold, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,0,0,16"/>

            <Button Content="Save Settings" Command="{Binding SaveCommand}" Padding="12,6" HorizontalAlignment="Left"/>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" FontStyle="Italic" Foreground="Green"/>
        </StackPanel>
    </Grid>
</UserControl>
