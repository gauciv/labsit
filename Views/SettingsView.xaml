<UserControl x:Class="LaboratorySitInSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PageBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="{StaticResource CardBgBrush}"
                Padding="24,20"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Settings Icon & Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="{StaticResource PrimaryBrush}"
                            CornerRadius="10"
                            Width="40"
                            Height="40"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="⚙" 
                                   FontSize="20"
                                   Foreground="{StaticResource TextOnDarkBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="System Settings" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Configure laboratory sit-in system preferences" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Reset to Defaults Button -->
                    <Button Content="Reset to Defaults" 
                            Command="{Binding ResetToDefaultsCommand}"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="16,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Save Changes Button -->
                    <Button Content="Save Changes" 
                            Command="{Binding SaveCommand}" 
                            Background="{StaticResource PrimaryBrush}"
                            Foreground="{StaticResource TextOnDarkBrush}"
                            BorderThickness="0"
                            Padding="24,10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="{StaticResource TrackBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area with ScrollViewer -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="24,20">
            <StackPanel MaxWidth="1400">
                
                <!-- Status Message -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,0,0,16"
                        Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0"
                                Background="{StaticResource ProgressBrush}"
                                CornerRadius="10"
                                Width="24"
                                Height="24"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="✓" 
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextOnDarkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StatusMessage}" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- Alarm Configuration Section -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="10"
                        Padding="24,20"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Alarm Configuration" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Alarm Threshold -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Alarm Threshold" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Maximum active sessions before triggering alarm" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <TextBox Grid.Column="1"
                                     Text="{Binding AlarmThreshold, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,8" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Margin="20,0,0,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                    Padding="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Enable Sound Alert -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Sound Notifications" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Play sound when alarm threshold is reached" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1"
                                      IsChecked="True"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="20,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Session Management Section -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="10"
                        Padding="24,20"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Session Management" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Auto Logout Duration -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Auto Logout Duration" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Auto logout after scheduled session for (minutes)" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <TextBox Grid.Column="1"
                                     Text="1" 
                                     Padding="12,8" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Margin="20,0,0,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                    Padding="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Require Student ID -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Require Student ID" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Students must enter ID to start session" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1"
                                      IsChecked="True"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="20,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Display Preferences Section -->
                <Border Background="{StaticResource CardBgBrush}"
                        CornerRadius="10"
                        Padding="24,20"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Display Preferences" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Refresh Interval -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Dashboard Refresh Interval" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Update dashboard every (seconds)" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <TextBox Grid.Column="1"
                                     Text="30" 
                                     Padding="12,8" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Margin="20,0,0,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ScrollViewer x:Name="PART_ContentHost" 
                                                                    Padding="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Show Session History -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Show Session History" 
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Display historical session data on dashboard" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1"
                                      IsChecked="True"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="20,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
