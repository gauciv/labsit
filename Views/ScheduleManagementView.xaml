<UserControl x:Class="LaboratorySitInSystem.Views.ScheduleManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:helpers="clr-namespace:LaboratorySitInSystem.Helpers">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="DayOfWeekValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="sys:DayOfWeek"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Background="{StaticResource CardBgBrush}"
                Padding="24,20"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title with Icon -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="{StaticResource AccentBrush}"
                            CornerRadius="10"
                            Width="40"
                            Height="40"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="📅" 
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Schedule Management" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Manage class schedules and timetables" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Student Selector -->
                <Border Grid.Column="2"
                        Background="{StaticResource CardBgSoftBrush}"
                        CornerRadius="8"
                        Padding="16,8"
                        MinWidth="350">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0"
                                   Text="Student:" 
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" 
                                   Margin="0,0,12,0"/>
                        
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Students}" 
                                  SelectedItem="{Binding SelectedStudent}"
                                  DisplayMemberPath="FullName"
                                  Background="{StaticResource CardBgBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  BorderThickness="1"
                                  Padding="8,6"
                                  FontSize="13"
                                  Visibility="{Binding IsStudentsEmpty, Converter={StaticResource InverseBoolToVisibility}}"/>
                        
                        <!-- Empty Students Message -->
                        <TextBlock Grid.Column="1"
                                   Text="No students available"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsStudentsEmpty, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" 
              Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                <!-- Schedule List Card -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBgBrush}"
                        CornerRadius="12"
                        Padding="0"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource CardBgSoftBrush}"
                                CornerRadius="12,12,0,0"
                                Padding="20,14"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="Class Schedule" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>

                        <!-- DataGrid with ScrollViewer -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsSchedulesEmpty, Converter={StaticResource InverseBoolToVisibility}}">
                            <DataGrid ItemsSource="{Binding Schedules}" 
                                      SelectedItem="{Binding SelectedSchedule}"
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True" 
                                      SelectionMode="Single"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowHeight="44"
                                      Margin="20,8,20,16">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Subject" Binding="{Binding SubjectName}" Width="*" FontSize="13"/>
                                    <DataGridTextColumn Header="Day" Binding="{Binding DayOfWeek}" Width="110" FontSize="13"/>
                                    <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat=hh\\:mm}" Width="110" FontSize="13"/>
                                    <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat=hh\\:mm}" Width="110" FontSize="13"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                        
                        <!-- Empty State for Schedules -->
                        <StackPanel Grid.Row="1" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Margin="40"
                                    Visibility="{Binding IsSchedulesEmpty, Converter={StaticResource BoolToVisibility}}">
                            
                            <!-- Icon -->
                            <Border Background="{StaticResource CardBgSoftBrush}"
                                    Width="80"
                                    Height="80"
                                    CornerRadius="40"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,24">
                                <TextBlock Text="📅" 
                                           FontSize="40"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Title -->
                            <TextBlock Text="No Schedules Yet" 
                                       FontSize="20" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            
                            <!-- Subtitle -->
                            <TextBlock FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"
                                       Margin="0,0,0,16">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="This student has no class schedules yet. Add a schedule using the form below."/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedStudent}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Select a student from the dropdown above to get started."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Form Card -->
                <Border Grid.Row="1"
                        Background="{StaticResource CardBgBrush}"
                        CornerRadius="12"
                        Padding="20,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A1D2E" 
                                          Opacity="0.06" 
                                          BlurRadius="16" 
                                          ShadowDepth="2" 
                                          Direction="270"/>
                    </Border.Effect>
                    
                    <StackPanel>
                        <!-- Form Header -->
                        <TextBlock Text="Schedule Details" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- Form Fields -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Subject Name -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Subject Name" 
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding EditSubjectName, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="10,8" 
                                         FontSize="13"
                                         Background="{StaticResource CardBgSoftBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8">
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                        Padding="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <!-- Day of Week -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Day of Week" 
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding Source={StaticResource DayOfWeekValues}}"
                                          SelectedItem="{Binding EditDayOfWeek}"
                                          Padding="10,8"
                                          FontSize="13"
                                          Background="{StaticResource CardBgSoftBrush}"
                                          BorderBrush="{StaticResource BorderBrush}"
                                          BorderThickness="1"/>
                            </StackPanel>

                            <!-- Start Time -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Start Time (HH:mm)" 
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding EditStartTime, StringFormat=hh\\:mm, UpdateSourceTrigger=LostFocus}" 
                                         Padding="10,8" 
                                         FontSize="13"
                                         Background="{StaticResource CardBgSoftBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8">
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                        Padding="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <!-- End Time -->
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="End Time (HH:mm)" 
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding EditEndTime, StringFormat=hh\\:mm, UpdateSourceTrigger=LostFocus}" 
                                         Padding="10,8" 
                                         FontSize="13"
                                         Background="{StaticResource CardBgSoftBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8">
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                        Padding="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <!-- Status Message -->
                        <Border Background="{StaticResource CardBgSoftBrush}"
                                CornerRadius="8"
                                Padding="10,8"
                                Margin="0,12,0,12"
                                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding StatusMessage}" 
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <!-- Clear Button -->
                            <Button Content="Clear" 
                                    Command="{Binding ClearFormCommand}"
                                    Background="Transparent"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="16,8"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Delete Button -->
                            <Button Content="Delete" 
                                    Command="{Binding DeleteCommand}"
                                    Background="#EF4444"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="16,8"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#DC2626"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Update Button -->
                            <Button Content="Update" 
                                    Command="{Binding UpdateCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="{StaticResource TextOnDarkBrush}"
                                    BorderThickness="0"
                                    Padding="16,8"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Add Button -->
                            <Button Content="Add Schedule" 
                                    Command="{Binding AddCommand}"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="{StaticResource TextOnDarkBrush}"
                                    BorderThickness="0"
                                    Padding="20,8"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
</UserControl>
