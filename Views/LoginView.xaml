<UserControl x:Class="LaboratorySitInSystem.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource CardBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left Side - Login Form -->
        <Grid Grid.Column="0" Background="{StaticResource CardBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo and Brand -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="40,30,40,0">
                <Image Source="/Assets/labsit logo.jpg" 
                       Width="50" 
                       Height="50" 
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"/>
                <TextBlock Text="LabSit" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Login Form Container -->
            <Border Grid.Row="1" 
                    Padding="40,20,40,40" 
                    VerticalAlignment="Center">
                <StackPanel MaxWidth="400">
                        
                        <!-- Login Panel -->
                        <StackPanel Visibility="{Binding IsResetMode, Converter={StaticResource InverseBoolToVisibility}}">
                            <!-- Welcome Header -->
                            <TextBlock Text="Welcome Back" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            
                            <TextBlock Text="Sign in to your Laboratory Sit in account" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,20"
                                       TextWrapping="Wrap"/>

                            <!-- Admin Login Label -->
                            <TextBlock Text="Admin Login" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- Username Field -->
                            <TextBlock Text="Username" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,10" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Margin="0,0,0,20"/>

                            <!-- Password Field -->
                            <TextBlock Text="Password" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <!-- Password Box (masked) -->
                                <PasswordBox x:Name="PasswordBox"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             Padding="12,10,80,10" 
                                             FontSize="14"
                                             Background="{StaticResource CardBgSoftBrush}"
                                             BorderBrush="{StaticResource BorderBrush}"
                                             BorderThickness="1">
                                    <PasswordBox.Style>
                                        <Style TargetType="PasswordBox">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </PasswordBox.Style>
                                </PasswordBox>
                                
                                <!-- Text Box (visible) -->
                                <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                                         Padding="12,10,80,10" 
                                         FontSize="14"
                                         Background="{StaticResource CardBgSoftBrush}"
                                         BorderBrush="{StaticResource BorderBrush}"
                                         BorderThickness="1">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                
                                <!-- Show/Hide Button -->
                                <Button Content="{Binding PasswordVisibilityText}"
                                        Command="{Binding TogglePasswordVisibilityCommand}"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,8,0"
                                        Cursor="Hand"
                                        Padding="4,2">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" 
                                                                            VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <!-- Remember Me Checkbox -->
                            <CheckBox Content="Remember me" 
                                      IsChecked="{Binding RememberMe}"
                                      FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}"
                                      Margin="0,0,0,24"/>

                            <!-- Error Message -->
                            <TextBlock Text="{Binding ErrorMessage}" 
                                       Foreground="Red" 
                                       FontSize="13"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                            <!-- Login Button -->
                            <Button Content="Login" 
                                    Command="{Binding LoginCommand}" 
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="{StaticResource TextOnDarkBrush}"
                                    BorderThickness="0"
                                    Padding="0,14"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,0,16">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Student Sit-In Button -->
                            <Button Content="Student Sit-In" 
                                    Command="{Binding GoToStudentSitInCommand}" 
                                    Background="{StaticResource CardBgSoftBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="0,14"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,0,20">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource CardBgSoftBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Reset Password Link -->
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink Command="{Binding ToggleResetModeCommand}"
                                           TextDecorations="None">
                                    <TextBlock Text="Reset Password" 
                                               FontSize="13"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <!-- Reset Password Panel -->
                        <StackPanel Visibility="{Binding IsResetMode, Converter={StaticResource BoolToVisibility}}">
                            <!-- Reset Header -->
                            <TextBlock Text="Reset Password" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"
                                       TextWrapping="Wrap"/>
                            
                            <TextBlock Text="Enter your username and new password" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,40"
                                       TextWrapping="Wrap"/>

                            <!-- Username Field -->
                            <TextBlock Text="Username" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,10" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Margin="0,0,0,20"/>

                            <!-- New Password Field -->
                            <TextBlock Text="New Password" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,10" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Margin="0,0,0,20"/>

                            <!-- Confirm Password Field -->
                            <TextBlock Text="Confirm Password" 
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="12,10" 
                                     FontSize="14"
                                     Background="{StaticResource CardBgSoftBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     Margin="0,0,0,20"/>

                            <!-- Reset Message -->
                            <TextBlock Text="{Binding ResetMessage}" 
                                       Foreground="OrangeRed" 
                                       FontSize="13"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ResetMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                            <!-- Reset Password Button -->
                            <Button Content="Reset Password" 
                                    Command="{Binding ResetPasswordCommand}" 
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="{StaticResource TextOnDarkBrush}"
                                    BorderThickness="0"
                                    Padding="0,14"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,0,20">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- Back to Login Link -->
                            <TextBlock HorizontalAlignment="Center">
                                <Hyperlink Command="{Binding ToggleResetModeCommand}"
                                           TextDecorations="None">
                                    <TextBlock Text="Back to Login" 
                                               FontSize="13"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
        </Grid>

        <!-- Right Side - Image -->
        <Grid Grid.Column="1" Background="{StaticResource PageBgBrush}">
            <Border Background="{StaticResource PageBgBrush}" 
                    Padding="20">
                <Border CornerRadius="12"
                        ClipToBounds="True"
                        Background="{StaticResource CardBgBrush}">
                    <Grid>
                        <!-- Laboratory Building Image -->
                        <Image Source="/Assets/ctu.jpg" 
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        
                        <!-- Fallback if image is not found -->
                        <Border Background="{StaticResource DarkCardBrush}"
                                Visibility="Collapsed">
                            <TextBlock Text="Laboratory Building&#x0a;&#x0a;Image not found:&#x0a;Assets/ctu.jpg" 
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextOnDarkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       LineHeight="24"/>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</UserControl>
