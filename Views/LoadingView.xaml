<UserControl x:Class="LaboratorySitInSystem.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource CardBgBrush}">
        <!-- Center Container -->
        <Border HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                MaxWidth="800"
                MaxHeight="600">
            <Grid>
                <!-- Video Player -->
                <MediaElement x:Name="LoadingVideo"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              MediaOpened="LoadingVideo_MediaOpened"
                              MediaEnded="LoadingVideo_MediaEnded"
                              MediaFailed="LoadingVideo_MediaFailed"
                              Volume="0.5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- Optional: Logo and Loading Text at Bottom -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,60"
                    Visibility="Collapsed">
            <Image Source="/Assets/labsit logo.jpg" 
                   Width="60" 
                   Height="60" 
                   Margin="0,0,0,16"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Loading..."
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
