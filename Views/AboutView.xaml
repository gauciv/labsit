<UserControl x:Class="LaboratorySitInSystem.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="False">
    <Grid Background="{StaticResource PageBgBrush}" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,20,0,10">
            <TextBlock Text="ABOUT" 
                       FontFamily="Segoe UI"
                       FontSize="38" 
                       FontWeight="Black" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Typography.CapitalSpacing" Value="True"/>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            
            <Border Width="60" 
                    Height="3" 
                    Background="{StaticResource PrimaryBrush}" 
                    CornerRadius="1.5"
                    HorizontalAlignment="Center" 
                    Margin="0,4,0,8"/>
            
            <TextBlock Text="Laboratory Sit-In System is designed to streamline laboratory access through efficient tracking, scheduling, and real-time session management."
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="700"
                       HorizontalAlignment="Center"
                       Margin="20,0,20,6"/>
            
            <TextBlock Text="Organize. Monitor. Optimize."
                       FontFamily="Segoe UI"
                       FontSize="14"
                       FontWeight="SemiBold"
                       FontStyle="Italic"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
        
        <!-- Card Zone -->
        <Grid Grid.Row="1" ClipToBounds="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Carousel with Arrows -->
            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="960" ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*" MaxWidth="800"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                
                <!-- LEFT ARROW BUTTON -->
                <Button Grid.Column="0"
                        Command="{Binding PreviousMemberCommand}"
                        Width="44" 
                        Height="44"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource DarkCardBrush}" 
                                    CornerRadius="22"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&lt;"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextOnDarkBrush}"/>
                </Button>
                
                <!-- SCROLLVIEWER WITH CARDS -->
                <ScrollViewer Grid.Column="1"
                              x:Name="CarouselScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Height="450"
                              ClipToBounds="False"
                              Padding="0,30,0,70">
                    
                    <StackPanel Orientation="Horizontal" x:Name="CardsPanel" ClipToBounds="False">
                        
                        <!-- Left Spacer -->
                        <Border x:Name="LeftSpacer" Width="220" Height="1"/>
                        
                        <!-- Card 0: Vincent -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card0" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale0" ScaleX="1.0" ScaleY="1.0" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[0].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[0].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[0].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[0].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Card 1: Justin -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card1" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale1" ScaleX="0.85" ScaleY="0.85" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[1].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[1].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[1].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[1].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Card 2: Dane -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card2" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale2" ScaleX="0.85" ScaleY="0.85" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[2].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[2].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[2].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[2].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Card 3: Elihu -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card3" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale3" ScaleX="0.85" ScaleY="0.85" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[3].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[3].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[3].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[3].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Card 4: Ashley -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card4" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale4" ScaleX="0.85" ScaleY="0.85" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[4].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                            <Border Background="{StaticResource CardBgSoftBrush}" Width="94" Height="94">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TeamMembers[4].HasImage}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding TeamMembers[4].Initials}" FontSize="36" FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[4].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[4].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[4].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Card 5: Romel -->
                        <Border Width="360" Height="320" Margin="16" CornerRadius="20" x:Name="Card5" Background="{StaticResource CardBgBrush}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="Scale5" ScaleX="0.85" ScaleY="0.85" CenterX="180" CenterY="160"/>
                            </Border.RenderTransform>
                            <Grid Margin="30">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="100" Height="100" Margin="0,5,0,15">
                                        <Ellipse Width="100" Height="100" StrokeThickness="3">
                                            <Ellipse.Stroke>
                                                <SolidColorBrush Color="{Binding Source={StaticResource PrimaryBrush}, Path=Color}"/>
                                            </Ellipse.Stroke>
                                            </Ellipse>
                                        <Grid Width="94" Height="94">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="47,47" RadiusX="47" RadiusY="47"/>
                                            </Grid.Clip>
                                            <Image Source="{Binding TeamMembers[5].ImagePath}" Stretch="UniformToFill" Width="94" Height="94"/>
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding TeamMembers[5].FirstName}" FontFamily="Segoe UI Semibold"
                                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TeamMembers[5].RoleUpperCase}" FontFamily="Segoe UI"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding TeamMembers[5].MottoWithPrefix}" FontFamily="Segoe UI"
                                               FontSize="11" FontStyle="Italic" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Right Spacer -->
                        <Border x:Name="RightSpacer" Width="220" Height="1"/>
                        
                    </StackPanel>
                </ScrollViewer>
                
                <!-- RIGHT ARROW BUTTON -->
                <Button Grid.Column="2"
                        Command="{Binding NextMemberCommand}"
                        Width="44" 
                        Height="44"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{StaticResource DarkCardBrush}" 
                                    CornerRadius="22"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="&gt;"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextOnDarkBrush}"/>
                </Button>
                
            </Grid>
            
            <!-- Navigation Dots -->
            <Border Grid.Row="1" 
                    Background="{StaticResource CardBgSoftBrush}"
                    CornerRadius="10"
                    Padding="8,6"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,20">
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    
                    <!-- Dot 1 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="0"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="0">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                    <!-- Dot 2 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="1"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="1">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                    <!-- Dot 3 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="2"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="2">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                    <!-- Dot 4 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="3"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="3">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                    <!-- Dot 5 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="4"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="4">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                    <!-- Dot 6 -->
                    <Button Command="{Binding SelectMemberByIndexCommand}"
                            CommandParameter="5"
                            Background="Transparent" 
                            BorderThickness="0"
                            Margin="5,0"
                            Cursor="Hand"
                            Padding="0"
                            VerticalAlignment="Center">
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Width" Value="9"/>
                                    <Setter Property="Height" Value="9"/>
                                    <Setter Property="Fill" Value="Transparent"/>
                                    <Setter Property="Stroke" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="StrokeThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentIndex}" Value="5">
                                            <Setter Property="Width" Value="12"/>
                                            <Setter Property="Height" Value="12"/>
                                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter Property="Stroke" Value="Transparent"/>
                                            <Setter Property="StrokeThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Button>
                    
                </StackPanel>
            </Border>
            
        </Grid>
        
    </Grid>
</UserControl>

